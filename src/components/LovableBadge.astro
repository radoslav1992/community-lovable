---
interface Props {
  verified: boolean | number;
  rank?: number | null;
  size?: 'sm' | 'md';
}

const { verified, rank = null, size = 'sm' } = Astro.props;
const label = rank ? `Lovable №${rank}` : 'Lovable билдър';
const style =
  rank && rank <= 3
    ? 'background:#FFECC9;color:#A66300'
    : rank
      ? 'background:#FFE0F1;color:#C4005D'
      : 'background:#FFE4D3;color:#C24E00';
const title = rank
  ? `№${rank} в класацията на общността по редакции в Lovable`
  : 'Потвърден Lovable профил';
---
{!!verified && (
  <span class:list={['lovable-badge', size]} style={style} title={title}>
    ⚡ {label}
  </span>
)}

<style>
  .lovable-badge {
    display: inline-flex; align-items: center; gap: 3px; border-radius: 99px;
    font-weight: 800; white-space: nowrap; vertical-align: middle;
  }
  .lovable-badge.sm { font-size: 11px; padding: 2px 8px; }
  .lovable-badge.md { font-size: 13px; padding: 4px 12px; }
</style>
