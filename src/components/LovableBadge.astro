---
interface Props {
  verified: boolean | number;
  topPercent?: number | null;
  size?: 'sm' | 'md';
}

const { verified, topPercent = null, size = 'sm' } = Astro.props;
const label = topPercent ? `Топ ${topPercent}% Lovable` : 'Lovable билдър';
const style = topPercent ? 'background:#FFE0F1;color:#C4005D' : 'background:#FFE4D3;color:#C24E00';
---
{!!verified && (
  <span class:list={['lovable-badge', size]} style={style} title="Потвърден Lovable профил">
    ⚡ {label}
  </span>
)}

<style>
  .lovable-badge {
    display: inline-flex; align-items: center; gap: 3px; border-radius: 99px;
    font-weight: 800; white-space: nowrap; vertical-align: middle;
  }
  .lovable-badge.sm { font-size: 11px; padding: 2px 8px; }
  .lovable-badge.md { font-size: 13px; padding: 4px 12px; }
</style>
