---
import { lovableTier } from '../lib/lovable';

interface Props {
  verified: boolean | number;
  rank?: number | null;
  edits?: number | null;
  size?: 'sm' | 'md';
}

const { verified, rank = null, edits = null, size = 'sm' } = Astro.props;
const tier = lovableTier(edits);
const label = tier ? `${tier.label}${rank ? ` №${rank}` : ''}` : 'Lovable билдър';
const style = tier ? tier.style : 'background:#FFE4D3;color:#C24E00';
const title = tier
  ? `Lovable ${tier.label}${rank ? ` · №${rank} в класацията на общността` : ''} (${edits!.toLocaleString('bg-BG')} редакции за последната година)`
  : 'Потвърден Lovable профил';
---
{!!verified && (
  <span class:list={['lovable-badge', size]} style={style} title={title}>
    ⚡ {label}
  </span>
)}

<style>
  .lovable-badge {
    display: inline-flex; align-items: center; gap: 3px; border-radius: 99px;
    font-weight: 800; white-space: nowrap; vertical-align: middle;
  }
  .lovable-badge.sm { font-size: 11px; padding: 2px 8px; }
  .lovable-badge.md { font-size: 13px; padding: 4px 12px; }
</style>
