---
import { initials, USER_GRADIENT } from '../lib/format';

const user = Astro.locals.user;
const path = Astro.url.pathname;

const tabs = [
  { href: '/', label: 'Начало', active: path === '/' || path.startsWith('/t/') },
  { href: '/sabitiya', label: 'Събития', active: path.startsWith('/sabitiya') },
  { href: '/novini', label: 'Новини', active: path.startsWith('/novini') },
  { href: '/obuchenie', label: 'Обучение', active: path.startsWith('/obuchenie') },
  { href: '/klasatsiya', label: 'Класация', active: path.startsWith('/klasatsiya') },
];
---
<header>
  <div class="inner">
    <a href="/" class="brand">
      <img src="/assets/logomark.svg" alt="Lovable" width="32" height="32" />
      <span class="brand-text">
        <span class="brand-name">Lovable Общност</span>
        <span class="brand-domain">COMMUNITYLOVABLE.BG</span>
      </span>
    </a>
    <nav>
      {tabs.map((tab) => (
        <a href={tab.href} class:list={['tab', { active: tab.active }]}>{tab.label}</a>
      ))}
    </nav>
    <div class="spacer"></div>
    <form action="/tarsene" method="get" class="search-form">
      <input name="q" placeholder="Търси в общността…" value={path === '/tarsene' ? Astro.url.searchParams.get('q') ?? '' : ''} />
    </form>
    {!user && <a href="/vhod" class="btn btn-dark">Вход</a>}
    {user && (
      <div class="user-area">
        <a href="/?post=new#composer" class="btn btn-dark">+ Публикация</a>
        <details class="menu">
          <summary>
            <span class="avatar user-avatar" style={`background:${USER_GRADIENT}`}>{initials(user.name)}</span>
          </summary>
          <div class="dropdown">
            <a href="/profil">Профил</a>
            <a href="/nastroyki">Настройки</a>
            {user.role === 'admin' && <a href="/admin">Админ панел</a>}
            <div class="sep"></div>
            <form action="/api/auth/logout" method="post">
              <button type="submit" class="logout">Изход</button>
            </form>
          </div>
        </details>
      </div>
    )}
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(247, 244, 237, 0.94);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 8px 24px;
    min-height: 64px;
    display: flex;
    align-items: center;
    gap: 12px 20px;
    flex-wrap: wrap;
  }
  .brand { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
  .brand img { width: 32px; height: 32px; object-fit: contain; }
  .brand-text { display: flex; flex-direction: column; line-height: 1.1; }
  .brand-name { font-weight: 800; font-size: 15px; letter-spacing: -0.01em; }
  .brand-domain { font-size: 10px; font-weight: 700; color: var(--accent); letter-spacing: 0.08em; }
  nav { display: flex; gap: 4px; flex-shrink: 0; }
  .tab {
    padding: 8px 14px;
    border-radius: 99px;
    font-size: 14px;
    font-weight: 700;
    color: var(--muted);
  }
  .tab:hover { color: var(--ink); background: var(--hover-bg); }
  .tab.active { background: var(--ink); color: var(--cream); }
  .spacer { flex: 1; }
  .search-form { flex: 1 1 120px; min-width: 0; max-width: 210px; }
  .search-form input {
    width: 100%;
    padding: 9px 14px;
    border-radius: 99px;
    border: 1px solid var(--border-input);
    background: #fff;
    font-size: 14px;
    outline: none;
    color: var(--ink);
  }
  .user-area { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
  .user-avatar { width: 38px; height: 38px; font-size: 13px; }
  details.menu { position: relative; }
  .dropdown {
    position: absolute;
    right: 0;
    top: 46px;
    width: 200px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: 0 12px 32px rgba(27, 27, 27, 0.12);
    padding: 6px;
    display: flex;
    flex-direction: column;
    animation: fadeUp 0.15s ease;
  }
  .dropdown a, .dropdown .logout {
    text-align: left;
    padding: 10px 12px;
    border: none;
    background: none;
    border-radius: 9px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    color: var(--ink);
    width: 100%;
    display: block;
  }
  .dropdown a:hover, .dropdown .logout:hover { background: var(--bg); }
  .dropdown .logout { color: var(--danger); }
  .dropdown .logout:hover { background: var(--danger-soft); }
  .sep { height: 1px; background: var(--border); margin: 4px 8px; }
</style>

<script>
  // Close the avatar dropdown when clicking anywhere outside it.
  document.addEventListener('click', (e) => {
    document.querySelectorAll('details.menu[open]').forEach((menu) => {
      if (!menu.contains(e.target as Node)) menu.removeAttribute('open');
    });
  });
</script>
