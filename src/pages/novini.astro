---
import Base from '../layouts/Base.astro';
import { bgDate, parseDbDate } from '../lib/format';

const db = Astro.locals.runtime.env.DB;

const news = (
  await db
    .prepare(`SELECT slug, title, excerpt, featured, published_at FROM news ORDER BY published_at DESC LIMIT 30`)
    .all<any>()
).results;

const description = 'Какво ново около Lovable — обобщено на български. Новини, акценти и анализи от българската общност.';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: news.map((n: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'NewsArticle',
        headline: n.title,
        description: n.excerpt,
        datePublished: parseDbDate(n.published_at).toISOString(),
        inLanguage: 'bg',
        url: `https://communitylovable.bg/novini#${n.slug}`,
      },
    })),
  },
];
---
<Base title="Новини — Българска Lovable Общност" description={description} canonicalPath="/novini" jsonLd={jsonLd}>
  <main>
    <h1 class="page-title">Новини</h1>
    <p class="page-sub">Какво ново около Lovable — обобщено на български.</p>
    <div class="list">
      {news.map((n: any) =>
        n.featured ? (
          <article class="featured" id={n.slug}>
            <img src="/assets/og-color.png" alt="" />
            <div class="overlay"></div>
            <div class="content">
              <div class="date">{bgDate(n.published_at)} · АКЦЕНТ</div>
              <h3>{n.title}</h3>
              <p>{n.excerpt}</p>
            </div>
          </article>
        ) : (
          <article class="card plain" id={n.slug}>
            <div class="date">{bgDate(n.published_at)}</div>
            <h3>{n.title}</h3>
            <p>{n.excerpt}</p>
          </article>
        )
      )}
    </div>
  </main>
</Base>

<style>
  main { max-width: 860px; margin: 0 auto; padding: 32px 24px; }
  .list { display: flex; flex-direction: column; gap: 16px; }
  .featured { border-radius: 18px; padding: 28px; position: relative; overflow: hidden; color: var(--cream); }
  .featured img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .overlay { position: absolute; inset: 0; background: rgba(27, 27, 27, 0.45); }
  .content { position: relative; }
  .featured .date { font-size: 13px; font-weight: 700; margin-bottom: 8px; opacity: 0.85; }
  .featured h3 { margin: 0 0 8px; font-size: 24px; font-weight: 900; letter-spacing: -0.01em; }
  .featured p { margin: 0; font-size: 15px; line-height: 1.55; max-width: 560px; }
  .plain { border-radius: 18px; padding: 24px; }
  .plain .date { font-size: 13px; color: var(--faint); font-weight: 700; margin-bottom: 8px; }
  .plain h3 { margin: 0 0 8px; font-size: 20px; font-weight: 800; letter-spacing: -0.01em; }
  .plain h3:hover { color: var(--accent); }
  .plain p { margin: 0; font-size: 15px; color: var(--muted); line-height: 1.55; }
</style>
