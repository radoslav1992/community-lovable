---
import Base from '../../../layouts/Base.astro';
import { LEVEL_STYLES } from '../../../lib/format';

const db = Astro.locals.runtime.env.DB;
const { slug, lesson: lessonSlug } = Astro.params;

const course = await db
  .prepare('SELECT id, slug, level, level_key, title FROM courses WHERE slug = ?')
  .bind(slug)
  .first<any>();
if (!course) return new Response(null, { status: 404, statusText: 'Not Found' });

const lessons = (
  await db
    .prepare('SELECT slug, title, content, sort FROM lessons WHERE course_id = ? ORDER BY sort')
    .bind(course.id)
    .all<any>()
).results;

const index = lessons.findIndex((l: any) => l.slug === lessonSlug);
if (index === -1) return new Response(null, { status: 404, statusText: 'Not Found' });

const lesson = lessons[index];
const prev = index > 0 ? lessons[index - 1] : null;
const next = index < lessons.length - 1 ? lessons[index + 1] : null;
const paragraphs = lesson.content.split(/\n\n+/).filter(Boolean);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'LearningResource',
    name: lesson.title,
    text: lesson.content,
    inLanguage: 'bg',
    url: `https://communitylovable.bg/obuchenie/${course.slug}/${lesson.slug}`,
    isPartOf: { '@type': 'Course', name: course.title, url: `https://communitylovable.bg/obuchenie/${course.slug}` },
  },
];
---
<Base
  title={`${lesson.title} — ${course.title}`}
  description={paragraphs[0]?.slice(0, 160) ?? course.title}
  canonicalPath={`/obuchenie/${course.slug}/${lesson.slug}`}
  ogType="article"
  jsonLd={jsonLd}
>
  <main>
    <a href={`/obuchenie/${course.slug}`} class="back">← {course.title}</a>
    <article class="card">
      <div class="crumbs">
        <span class="tag" style={LEVEL_STYLES[course.level_key] ?? LEVEL_STYLES.beginner}>{course.level}</span>
        <span class="counter">Урок {index + 1} от {lessons.length}</span>
      </div>
      <h1>{lesson.title}</h1>
      {paragraphs.map((p: string) => <p>{p}</p>)}
    </article>
    <nav class="pager">
      {prev
        ? <a href={`/obuchenie/${course.slug}/${prev.slug}`} class="btn btn-light">← {prev.title}</a>
        : <span></span>}
      {next
        ? <a href={`/obuchenie/${course.slug}/${next.slug}`} class="btn btn-dark">{next.title} →</a>
        : <a href="/obuchenie" class="btn btn-dark">Завърши курса ✓</a>}
    </nav>
  </main>
</Base>

<style>
  main { max-width: 760px; margin: 0 auto; padding: 28px 24px; display: flex; flex-direction: column; gap: 16px; }
  .back { align-self: flex-start; color: var(--muted); font-weight: 700; font-size: 14px; padding: 4px 0; }
  .back:hover { color: var(--accent); }
  article { border-radius: 18px; padding: 28px; }
  .crumbs { display: flex; gap: 12px; align-items: center; margin-bottom: 12px; }
  .crumbs .tag { letter-spacing: 0.04em; }
  .counter { font-size: 13px; color: var(--faint); font-weight: 700; }
  h1 { margin: 0 0 16px; font-size: 24px; font-weight: 900; line-height: 1.3; letter-spacing: -0.01em; }
  p { margin: 0 0 14px; font-size: 16px; line-height: 1.65; color: var(--ink-soft); }
  p:last-child { margin-bottom: 0; }
  .pager { display: flex; justify-content: space-between; gap: 10px; flex-wrap: wrap; }
  .pager .btn { max-width: 100%; white-space: normal; text-align: center; }
</style>
