---
import Base from '../layouts/Base.astro';
import { LEVEL_STYLES } from '../lib/format';

const db = Astro.locals.runtime.env.DB;

const [coursesRes, articlesRes] = await db.batch([
  db.prepare('SELECT slug, level, level_key, title, description, meta FROM courses ORDER BY sort'),
  db.prepare('SELECT title, meta, url FROM articles ORDER BY sort'),
]);
const courses = coursesRes.results as any[];
const articles = articlesRes.results as any[];

const description = 'Кратки курсове и материали за Lovable на български — от нулата до пуснат продукт.';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: courses.map((c: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Course',
        name: c.title,
        description: c.description,
        inLanguage: 'bg',
        provider: { '@type': 'Organization', name: 'Българска Lovable Общност', url: 'https://communitylovable.bg' },
      },
    })),
  },
];
---
<Base title="Обучение — Българска Lovable Общност" description={description} canonicalPath="/obuchenie" jsonLd={jsonLd}>
  <main>
    <h1 class="page-title">Обучение</h1>
    <p class="page-sub">Кратки курсове и материали на български — от нулата до пуснат продукт.</p>

    <div class="courses">
      {courses.map((c: any) => (
        <div class="card course">
          <span class="tag" style={LEVEL_STYLES[c.level_key] ?? LEVEL_STYLES.beginner}>{c.level}</span>
          <h3><a href={`/obuchenie/${c.slug}`}>{c.title}</a></h3>
          <p>{c.description}</p>
          <div class="meta">{c.meta}</div>
          <a href={`/obuchenie/${c.slug}`} class="btn btn-dark">Започни курса</a>
        </div>
      ))}
    </div>

    <h2>Статии и материали</h2>
    <div class="card articles">
      {articles.map((a: any) => (
        <a href={a.url} class="article-row">
          <div>
            <div class="a-title">{a.title}</div>
            <div class="a-meta">{a.meta}</div>
          </div>
          <span class="arrow">→</span>
        </a>
      ))}
    </div>
  </main>
</Base>

<style>
  main { max-width: 1000px; margin: 0 auto; padding: 32px 24px; }
  .courses {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px; margin-bottom: 36px;
  }
  .course { border-radius: 18px; padding: 22px; display: flex; flex-direction: column; gap: 10px; }
  .course .tag { align-self: flex-start; letter-spacing: 0.04em; }
  .course h3 { margin: 0; font-size: 19px; font-weight: 800; line-height: 1.3; letter-spacing: -0.01em; }
  .course h3 a:hover { color: var(--accent); }
  .course p { margin: 0; font-size: 14px; color: var(--muted); line-height: 1.5; flex: 1; }
  .course .meta { font-size: 13px; color: var(--faint); font-weight: 700; }
  h2 { font-size: 18px; font-weight: 800; margin: 0 0 14px; }
  .articles { border-radius: 18px; overflow: hidden; padding: 0; }
  .article-row {
    padding: 16px 22px; border-bottom: 1px solid var(--divider);
    display: flex; justify-content: space-between; gap: 12px; align-items: center;
  }
  .article-row:last-child { border-bottom: none; }
  .article-row:hover { background: var(--card-hover); }
  .a-title { font-weight: 800; font-size: 15px; }
  .a-meta { font-size: 13px; color: var(--faint); font-weight: 600; }
  .arrow { color: var(--accent); font-weight: 800; }
</style>
