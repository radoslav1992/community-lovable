---
import Base from '../layouts/Base.astro';
import { initials, avatarGradient, ROLE_LABELS, ROLE_STYLES, bgDate } from '../lib/format';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/vhod');
if (user.role !== 'admin') return Astro.redirect('/');

const db = Astro.locals.runtime.env.DB;
const [usersRes, reportsRes, eventsRes, newsRes, digestRes] = await db.batch([
  db.prepare('SELECT id, name, email, role, blocked FROM users ORDER BY created_at ASC LIMIT 100'),
  db.prepare(`SELECT id, title, reason, reporter_name FROM reports WHERE status = 'pending' ORDER BY created_at ASC`),
  db.prepare(`SELECT e.id, e.title, e.starts_at, e.is_live, e.place, e.description,
    (SELECT COUNT(*) FROM rsvps r WHERE r.event_id = e.id) AS rsvp_count
    FROM events e ORDER BY e.starts_at DESC LIMIT 100`),
  db.prepare('SELECT id, slug, title, excerpt, body, featured, published_at FROM news ORDER BY published_at DESC LIMIT 100'),
  db.prepare(`SELECT COUNT(*) AS subscribers FROM users
    WHERE notif_digest = 1 AND blocked = 0 AND (password_hash IS NOT NULL OR oauth_provider IS NOT NULL)`),
]);
const users = usersRes.results as any[];
const reports = reportsRes.results as any[];
const events = eventsRes.results as any[];
const news = newsRes.results as any[];
const subscribers = (digestRes.results as any[])[0]?.subscribers ?? 0;

const error = Astro.url.searchParams.get('greshka');
const ERRORS: Record<string, string> = {
  sabitie: 'Събитието трябва да има заглавие и валидна дата.',
  novina: 'Новината трябва да има заглавие и текст.',
};

const byuletin = Astro.url.searchParams.get('byuletin');
let byuletinMsg: string | null = null;
if (byuletin === 'prazen') {
  byuletinMsg = 'Няма нищо ново тази седмица — бюлетинът беше пропуснат.';
} else if (byuletin?.startsWith('ok-')) {
  const [, sent, failed] = byuletin.split('-');
  byuletinMsg = `Изпратени: ${sent}${Number(failed) > 0 ? ` · неуспешни: ${failed}` : ''}.`;
}
---
<Base title="Админ панел — Българска Lovable Общност" description="Управление на общността." noindex={true}>
  <main>
    <div>
      <h1>Админ панел</h1>
      <p class="sub">Управление на потребители, докладвано съдържание, събития и новини.</p>
    </div>

    {error && <div class="notice notice-error">{ERRORS[error] ?? 'Нещо се обърка.'}</div>}

    <section class="card">
      <div class="sec-head">ПОТРЕБИТЕЛИ</div>
      {users.map((u: any, i: number) => (
        <div class="user-row">
          <div class="avatar u-avatar" style={`background:${avatarGradient(i)}`}>{initials(u.name)}</div>
          <div class="u-name">{u.name}</div>
          <div class="u-email">{u.email}</div>
          <span class="tag" style={ROLE_STYLES[u.role]}>{ROLE_LABELS[u.role]}</span>
          <form method="post" action="/api/admin/block">
            <input type="hidden" name="user_id" value={u.id} />
            {u.id === user.id ? (
              <span class="self">това си ти</span>
            ) : (
              <button type="submit" class:list={['block-btn', { blocked: !!u.blocked }]}>
                {u.blocked ? 'Отблокирай' : 'Блокирай'}
              </button>
            )}
          </form>
        </div>
      ))}
    </section>

    <section class="card">
      <div class="sec-head">ДОКЛАДВАНО СЪДЪРЖАНИЕ</div>
      {reports.length === 0 && <div class="no-reports">Няма чакащи доклади.</div>}
      {reports.map((r: any) => (
        <div class="report-row">
          <div class="r-info">
            <div class="r-title">{r.title}</div>
            <div class="r-reason">Причина: {r.reason} · от {r.reporter_name}</div>
          </div>
          <form method="post" action="/api/admin/report">
            <input type="hidden" name="report_id" value={r.id} />
            <button type="submit" name="action" value="approve" class="btn btn-light approve">Одобри</button>
          </form>
          <form method="post" action="/api/admin/report">
            <input type="hidden" name="report_id" value={r.id} />
            <button type="submit" name="action" value="hide" class="btn btn-danger hide">Скрий поста</button>
          </form>
        </div>
      ))}
    </section>

    <section class="card" id="sabitiya">
      <div class="sec-head">СЪБИТИЯ</div>

      <details class="editor">
        <summary>+ Ново събитие</summary>
        <form method="post" action="/api/admin/event" class="ed-form">
          <input type="hidden" name="action" value="create" />
          <label>Заглавие<input class="input" name="title" maxlength="200" required /></label>
          <div class="ed-row">
            <label>Дата<input class="input" type="date" name="date" required /></label>
            <label>Час<input class="input" type="time" name="time" value="18:30" /></label>
            <label>Формат
              <select class="input" name="is_live">
                <option value="1">На живо</option>
                <option value="0">Онлайн</option>
              </select>
            </label>
          </div>
          <label>Място<input class="input" name="place" maxlength="200" placeholder="📍 betahaus, София · 18:30 – 21:00" /></label>
          <label>Описание<textarea class="input" name="description" rows="3" maxlength="2000"></textarea></label>
          <button type="submit" class="btn btn-dark ed-submit">Създай събитие</button>
        </form>
      </details>

      {events.map((ev: any) => (
        <div class="item-row">
          <div class="item-main">
            <div class="item-title">{ev.title} {ev.is_live ? '' : '· онлайн'}</div>
            <div class="item-meta">{bgDate(ev.starts_at)} · {ev.starts_at.slice(11, 16)} · {ev.rsvp_count} записани</div>
          </div>
          <details class="editor inline">
            <summary class="edit-link">Редактирай</summary>
            <form method="post" action="/api/admin/event" class="ed-form">
              <input type="hidden" name="action" value="update" />
              <input type="hidden" name="id" value={ev.id} />
              <label>Заглавие<input class="input" name="title" value={ev.title} maxlength="200" required /></label>
              <div class="ed-row">
                <label>Дата<input class="input" type="date" name="date" value={ev.starts_at.slice(0, 10)} required /></label>
                <label>Час<input class="input" type="time" name="time" value={ev.starts_at.slice(11, 16)} /></label>
                <label>Формат
                  <select class="input" name="is_live">
                    <option value="1" selected={!!ev.is_live}>На живо</option>
                    <option value="0" selected={!ev.is_live}>Онлайн</option>
                  </select>
                </label>
              </div>
              <label>Място<input class="input" name="place" value={ev.place} maxlength="200" /></label>
              <label>Описание<textarea class="input" name="description" rows="3" maxlength="2000">{ev.description}</textarea></label>
              <button type="submit" class="btn btn-dark ed-submit">Запази</button>
            </form>
          </details>
          <form method="post" action="/api/admin/event" onsubmit="return confirm('Да изтрия ли събитието?')">
            <input type="hidden" name="action" value="delete" />
            <input type="hidden" name="id" value={ev.id} />
            <button type="submit" class="btn btn-danger small">Изтрий</button>
          </form>
        </div>
      ))}
      {events.length === 0 && <div class="empty">Няма събития — добави първото.</div>}
    </section>

    <section class="card" id="novini">
      <div class="sec-head">НОВИНИ</div>

      <details class="editor">
        <summary>+ Нова новина</summary>
        <form method="post" action="/api/admin/news" class="ed-form">
          <input type="hidden" name="action" value="create" />
          <label>Заглавие<input class="input" name="title" maxlength="200" required /></label>
          <label>Кратко резюме (по избор)<input class="input" name="excerpt" maxlength="300" placeholder="Ако е празно, взима се началото на текста" /></label>
          <label>Текст<textarea class="input" name="body" rows="6" maxlength="20000" required placeholder="Параграфите се разделят с празен ред."></textarea></label>
          <label class="check"><input type="checkbox" name="featured" value="1" /> Акцент (голяма карта най-отгоре)</label>
          <button type="submit" class="btn btn-dark ed-submit">Публикувай новина</button>
        </form>
      </details>

      {news.map((n: any) => (
        <div class="item-row">
          <div class="item-main">
            <div class="item-title">{n.title} {n.featured ? '· ★ акцент' : ''}</div>
            <div class="item-meta">{bgDate(n.published_at)} · <a href={`/novini/${n.slug}`} class="view-link">виж →</a></div>
          </div>
          <details class="editor inline">
            <summary class="edit-link">Редактирай</summary>
            <form method="post" action="/api/admin/news" class="ed-form">
              <input type="hidden" name="action" value="update" />
              <input type="hidden" name="id" value={n.id} />
              <label>Заглавие<input class="input" name="title" value={n.title} maxlength="200" required /></label>
              <label>Кратко резюме<input class="input" name="excerpt" value={n.excerpt} maxlength="300" /></label>
              <label>Текст<textarea class="input" name="body" rows="6" maxlength="20000" required>{n.body}</textarea></label>
              <label class="check"><input type="checkbox" name="featured" value="1" checked={!!n.featured} /> Акцент</label>
              <button type="submit" class="btn btn-dark ed-submit">Запази</button>
            </form>
          </details>
          <form method="post" action="/api/admin/news" onsubmit="return confirm('Да изтрия ли новината?')">
            <input type="hidden" name="action" value="delete" />
            <input type="hidden" name="id" value={n.id} />
            <button type="submit" class="btn btn-danger small">Изтрий</button>
          </form>
        </div>
      ))}
      {news.length === 0 && <div class="empty">Няма новини — добави първата.</div>}
    </section>

    <section class="card" id="byuletin">
      <div class="sec-head">СЕДМИЧЕН БЮЛЕТИН</div>
      <div class="digest-box">
        {byuletinMsg && <div class="notice notice-ok">{byuletinMsg}</div>}
        <p class="digest-info">
          <strong>{subscribers}</strong> абонати · изпраща се автоматично всеки петък в 10:00 ч. с
          най-обсъжданите публикации, предстоящите събития и новините от седмицата.
        </p>
        <div class="digest-actions">
          <form method="post" action="/api/admin/digest">
            <input type="hidden" name="action" value="test" />
            <button type="submit" class="btn btn-light">Изпрати тест до мен</button>
          </form>
          <form method="post" action="/api/admin/digest" onsubmit={`return confirm('Да изпратя ли бюлетина до всичките ${subscribers} абонати сега?')`}>
            <input type="hidden" name="action" value="send" />
            <button type="submit" class="btn btn-dark">Изпрати до всички сега</button>
          </form>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  main { max-width: 860px; margin: 0 auto; padding: 32px 24px; display: flex; flex-direction: column; gap: 20px; }
  h1 { font-size: 28px; font-weight: 900; margin: 0 0 4px; letter-spacing: -0.02em; }
  .sub { margin: 0; color: var(--muted); font-size: 15px; }
  section.card { border-radius: 18px; overflow: hidden; padding: 0; }
  .sec-head {
    padding: 16px 22px; border-bottom: 1px solid var(--divider);
    font-size: 13px; font-weight: 800; letter-spacing: 0.06em; color: var(--muted);
  }
  .user-row {
    padding: 14px 22px; border-bottom: 1px solid var(--divider);
    display: grid; grid-template-columns: 40px 1.4fr 1.6fr auto auto;
    gap: 14px; align-items: center;
  }
  .user-row:last-child { border-bottom: none; }
  .u-avatar { width: 36px; height: 36px; font-size: 12px; }
  .u-name { font-weight: 800; font-size: 15px; }
  .u-email { font-size: 14px; color: var(--muted); overflow: hidden; text-overflow: ellipsis; }
  .block-btn {
    padding: 7px 14px; border-radius: 99px; font-weight: 700; font-size: 13px;
    cursor: pointer; white-space: nowrap;
    border: 1px solid var(--border-input); background: #fff; color: var(--danger);
  }
  .block-btn.blocked { border: none; background: var(--ink); color: var(--cream); }
  .self { font-size: 12px; color: var(--faint); font-weight: 600; white-space: nowrap; }
  .no-reports { padding: 22px; font-size: 14px; color: var(--faint); font-weight: 600; }
  .report-row {
    padding: 14px 22px; border-bottom: 1px solid var(--divider);
    display: flex; gap: 14px; align-items: center; flex-wrap: wrap;
  }
  .report-row:last-child { border-bottom: none; }
  .r-info { flex: 1; min-width: 220px; }
  .r-title { font-weight: 800; font-size: 15px; }
  .r-reason { font-size: 13px; color: var(--danger); font-weight: 700; }
  .approve { padding: 8px 14px; font-size: 13px; color: var(--ink-body); }
  .hide { padding: 8px 14px; font-size: 13px; }

  .empty { padding: 22px; font-size: 14px; color: var(--faint); font-weight: 600; }
  details.editor > summary {
    list-style: none; cursor: pointer; padding: 14px 22px;
    font-size: 14px; font-weight: 800; color: var(--accent);
    border-bottom: 1px solid var(--divider);
  }
  details.editor > summary::-webkit-details-marker { display: none; }
  details.editor > summary:hover { background: var(--card-hover); }
  details.editor[open] > summary { background: var(--card-hover); }
  .ed-form {
    padding: 16px 22px; border-bottom: 1px solid var(--divider);
    display: flex; flex-direction: column; gap: 12px; background: var(--card-hover);
  }
  .ed-form label { font-size: 13px; font-weight: 700; color: var(--muted); }
  .ed-form label .input { margin-top: 6px; }
  .ed-form textarea.input { resize: vertical; }
  .ed-row { display: flex; gap: 12px; flex-wrap: wrap; }
  .ed-row label { flex: 1; min-width: 130px; }
  .ed-submit { align-self: flex-start; }
  .check { display: flex; align-items: center; gap: 8px; font-size: 14px !important; color: var(--ink) !important; }
  .item-row {
    padding: 14px 22px; border-bottom: 1px solid var(--divider);
    display: flex; gap: 14px; align-items: center; flex-wrap: wrap;
  }
  .item-row:last-child { border-bottom: none; }
  .item-main { flex: 1; min-width: 220px; }
  .item-title { font-weight: 800; font-size: 15px; }
  .item-meta { font-size: 13px; color: var(--faint); font-weight: 600; }
  .view-link { color: var(--accent); }
  details.editor.inline { flex-basis: 100%; order: 3; }
  details.editor.inline > summary {
    padding: 6px 0; border-bottom: none; font-size: 13px; font-weight: 700;
  }
  details.editor.inline > summary:hover { background: none; text-decoration: underline; }
  details.editor.inline .ed-form { border-radius: 12px; border: 1px solid var(--border); }
  .btn.small { padding: 7px 14px; font-size: 13px; }
  .item-row > form:last-child { order: 2; }
  .digest-box { padding: 18px 22px; display: flex; flex-direction: column; gap: 14px; }
  .digest-info { margin: 0; font-size: 14px; color: var(--muted); line-height: 1.55; }
  .digest-info strong { color: var(--ink); }
  .digest-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  @media (max-width: 640px) {
    .user-row { grid-template-columns: 40px 1fr auto; }
    .u-email { display: none; }
    .user-row .tag { display: none; }
  }
</style>
