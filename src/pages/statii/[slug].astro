---
import Base from '../../layouts/Base.astro';

const db = Astro.locals.runtime.env.DB;
const { slug } = Astro.params;

const article = await db
  .prepare('SELECT slug, title, meta, content FROM articles WHERE slug = ?')
  .bind(slug)
  .first<any>();

if (!article || !article.content) return new Response(null, { status: 404, statusText: 'Not Found' });

const paragraphs = article.content.split(/\n\n+/).filter(Boolean);
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: article.title,
    articleBody: article.content,
    inLanguage: 'bg',
    url: `https://communitylovable.bg/statii/${article.slug}`,
    publisher: { '@type': 'Organization', name: 'Българска Lovable Общност', url: 'https://communitylovable.bg' },
  },
];
---
<Base
  title={`${article.title} — Българска Lovable Общност`}
  description={paragraphs[0]?.slice(0, 160) ?? article.title}
  canonicalPath={`/statii/${article.slug}`}
  ogType="article"
  jsonLd={jsonLd}
>
  <main>
    <a href="/obuchenie" class="back">← Обучение</a>
    <article class="card">
      <div class="meta">{article.meta}</div>
      <h1>{article.title}</h1>
      {paragraphs.map((p: string) => <p>{p}</p>)}
    </article>
  </main>
</Base>

<style>
  main { max-width: 760px; margin: 0 auto; padding: 28px 24px; display: flex; flex-direction: column; gap: 16px; }
  .back { align-self: flex-start; color: var(--muted); font-weight: 700; font-size: 14px; padding: 4px 0; }
  .back:hover { color: var(--accent); }
  article { border-radius: 18px; padding: 28px; }
  .meta { font-size: 13px; color: var(--faint); font-weight: 700; margin-bottom: 8px; }
  h1 { margin: 0 0 16px; font-size: 26px; font-weight: 900; line-height: 1.25; letter-spacing: -0.01em; }
  p { margin: 0 0 14px; font-size: 16px; line-height: 1.65; color: var(--ink-soft); }
  p:last-child { margin-bottom: 0; }
</style>
